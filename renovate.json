{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],

  "timezone": "Europe/Warsaw",

  "schedule": ["every weekend"],

  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rebaseWhen": "behind-base-branch",

  "minimumReleaseAge": "3 days",

  "labels": ["dependencies"],

  "packageRules": [
    {
      "description": "Spring Boot — group all Spring updates into one PR",
      "groupName": "Spring Framework",
      "minimumReleaseAge": "7 days",
      "matchPackageNames": [
        "/^org.springframework/"
      ]
    },
    {
      "description": "Spring Boot parent — extra caution, wait 7 days",
      "matchPackageNames": ["org.springframework.boot:spring-boot-starter-parent"],
      "groupName": "Spring Boot",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Kafka — group Kafka client and streams together",
      "groupName": "Apache Kafka",
      "matchPackageNames": [
        "/^org.apache.kafka/"
      ]
    },
    {
      "description": "Testcontainers — group all testcontainers modules",
      "groupName": "Testcontainers",
      "matchPackageNames": [
        "/^org.testcontainers/"
      ]
    },
    {
      "description": "AWS / GCP SDKs — major versions require manual review",
      "minimumReleaseAge": "14 days",
      "labels": ["dependencies", "needs-review"],
      "matchPackageNames": [
        "/^com.google.cloud/",
        "/^software.amazon/"
      ]
    },
    {
      "description": "GitHub Actions — pin to SHA and auto-update",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Docker base images — group all Dockerfile updates",
      "matchManagers": ["dockerfile"],
      "groupName": "Docker base images",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Patch and minor updates — auto-merge when CI passes",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": false,
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "description": "Major updates — always require manual review",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update"],
      "automerge": false
    }
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"]
  },

  "osvVulnerabilityAlerts": true
}
