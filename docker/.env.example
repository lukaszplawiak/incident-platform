# ============================================================
# Incident Platform — environment variables template
# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit it.
#
# Generate JWT_SECRET:      openssl rand -base64 64
# Generate MFA_ENCRYPTION_KEY: openssl rand -base64 32
# ============================================================

# ── Required ─────────────────────────────────────────────────

# Shared JWT secret — MUST be identical across all services.
# Min 64 characters. Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# AES-256-GCM key for encrypting TOTP secrets at rest (auth-service).
# Exactly 32 bytes base64-encoded. Generate: openssl rand -base64 32
MFA_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# PostgreSQL password
POSTGRES_PASSWORD=incident_secret

# ── Optional — override defaults ─────────────────────────────

# JWT token TTLs (ISO-8601 duration)
JWT_ACCESS_TOKEN_TTL=PT15M
JWT_REFRESH_TOKEN_TTL=P30D
JWT_SERVICE_TOKEN_TTL=PT1H

# CORS — Angular/React dev server
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Application base URL (used in invite emails)
APP_BASE_URL=http://localhost:8087

# ── Mail (SMTP) ───────────────────────────────────────────────
# For local dev, use MailHog (included in docker-compose.yml):
#   http://localhost:8025 — MailHog UI
# For production, set real SMTP credentials.
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
INVITE_EMAIL_FROM=noreply@incident-platform.local
NOTIFICATION_FALLBACK_EMAIL=oncall@incident-platform.local

# ── Slack (optional) ─────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── AI / Postmortem generation (optional) ────────────────────
GEMINI_API_KEY=

# ── Service ports (optional — override defaults) ─────────────
AUTH_SERVICE_PORT=8087
INGESTION_SERVICE_PORT=8081
INCIDENT_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083
ESCALATION_SERVICE_PORT=8084
POSTMORTEM_SERVICE_PORT=8085
ONCALL_SERVICE_PORT=8086
