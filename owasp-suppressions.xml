<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        OWASP Dependency-Check false positive suppressions.

        How to add a suppression:
        1. Run: ./mvnw dependency-check:aggregate
        2. Open: target/dependency-check-report.html
        3. Find the false positive — add an entry below with:
              <notes>  - why this is a false positive or why it cannot be fixed
              <until>  - expiration date (max 90 days for real issues, 1 year for unfixable)

        All CVE-2026-* entries below are very recently published NVD entries.
        They are suppressed because:
          a) No patched version exists in the 3.x ecosystem (require Spring Boot 4.x), OR
          b) The CVE is incorrectly attributed to this library version (false positive)
        Each entry will be re-evaluated when it expires.
    -->

    <!-- ═══════════════════════════════════════════════════════════════════════
         angus-activation
         CVE-2025-7962 (CVSS 7.5)
         Transitive dependency via Spring Boot. No patched version available
         in the Spring Boot 3.x BOM at time of writing (2026-06-06).
         ═══════════════════════════════════════════════════════════════════════ -->
    <suppress until="2026-12-31Z">
        <notes>
            CVE-2025-7962: angus-activation 2.0.3 — no patched version available
            in Spring Boot 3.x BOM at time of writing. Will be re-evaluated when
            Spring Boot 3.x ships a patched version or when migrating to 4.x.
            Reviewed: 2026-06-06.
        </notes>
        <packageUrl regex="true">^pkg:maven/org\.eclipse\.angus/angus\-activation@.*$</packageUrl>
        <cve>CVE-2025-7962</cve>
    </suppress>

