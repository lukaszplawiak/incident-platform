    <!-- ═══════════════════════════════════════════════════════════════════════
         log4j-api / log4j-to-slf4j — CVE-2026-34477/34478/34479/34480/34481,
                                       CVE-2025-68161
         VERDICT: FALSE POSITIVE

         All six CVEs affect log4j-core (the implementation module) — specifically
         XmlLayout, Rfc5424Layout, SMTP/Socket/Syslog appenders with TLS, and the
         Log4j1 bridge. Fix is in log4j-core 2.25.4.

         This project depends only on log4j-api (API/facade module) and
         log4j-to-slf4j (bridge module that redirects log4j2 API calls to
         SLF4J) — neither contains appenders, layouts, or network code.
         OWASP incorrectly matches log4j-core CVEs against these sibling
         artifacts because they share the same groupId and release version.

         Regex widened from log4j-api only to log4j-(api|to-slf4j) after
         log4j-to-slf4j-2.24.3.jar started reporting CVE-2026-34477 and
         CVE-2026-34479 (2026-06-13) — same false-positive cause, different
         sibling artifact from the same log4j2 release.

         Reference: https://logging.apache.org/security.html
         ═══════════════════════════════════════════════════════════════════════ -->
    <suppress until="2026-12-31Z">
        <notes>
            FALSE POSITIVE: CVE-2026-34477 affects log4j-core (XmlLayout/appenders).
            This project uses only log4j-api and log4j-to-slf4j, neither of which
            contains appenders or network code. OWASP incorrectly maps CVEs
            between log4j2 sibling modules sharing the same groupId/version.
        </notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-(api|to\-slf4j)@.*$</packageUrl>
        <cve>CVE-2026-34477</cve>
    </suppress>
    <suppress until="2026-12-31Z">
        <notes>
            FALSE POSITIVE: CVE-2026-34478 affects log4j-core (Rfc5424Layout CRLF
            injection). This project uses only log4j-api and log4j-to-slf4j.
            See CVE-2026-34477 note.
        </notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-(api|to\-slf4j)@.*$</packageUrl>
        <cve>CVE-2026-34478</cve>
    </suppress>
    <suppress until="2026-12-31Z">
        <notes>
            FALSE POSITIVE: CVE-2026-34479 affects log4j-core (Log4j1XmlLayout XML
            escaping). This project uses only log4j-api and log4j-to-slf4j.
            See CVE-2026-34477 note.
        </notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-(api|to\-slf4j)@.*$</packageUrl>
        <cve>CVE-2026-34479</cve>
    </suppress>
    <suppress until="2026-12-31Z">
        <notes>
            FALSE POSITIVE: CVE-2026-34480 affects log4j-core (XmlLayout via
            Log4jXmlObjectMapper). This project uses only log4j-api and
            log4j-to-slf4j. See CVE-2026-34477 note.
        </notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-(api|to\-slf4j)@.*$</packageUrl>
        <cve>CVE-2026-34480</cve>
    </suppress>
    <suppress until="2026-12-31Z">
        <notes>
            FALSE POSITIVE: CVE-2026-34481 affects log4j-core appenders.
            This project uses only log4j-api and log4j-to-slf4j.
            See CVE-2026-34477 note.
        </notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-(api|to\-slf4j)@.*$</packageUrl>
        <cve>CVE-2026-34481</cve>
    </suppress>
    <suppress until="2026-12-31Z">
        <notes>
            FALSE POSITIVE: CVE-2025-68161 affects log4j-core TLS hostname
            verification in SMTP/Socket/Syslog appenders. This project uses only
            log4j-api and log4j-to-slf4j. See CVE-2026-34477 note.
        </notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-(api|to\-slf4j)@.*$</packageUrl>
        <cve>CVE-2025-68161</cve>
    </suppress>

    <!-- ═══════════════════════════════════════════════════════════════════════
         micrometer-registry-prometheus — CVE-2026-42154
         VERDICT: FALSE POSITIVE

         OWASP matches CPE cpe:2.3:a:prometheus:prometheus against
         micrometer-registry-prometheus because of the word "prometheus" in the
         artifact name. micrometer-registry-prometheus is a Micrometer metrics
         bridge — it is not the Prometheus server. They are completely different
         projects from different organizations.
         ═══════════════════════════════════════════════════════════════════════ -->
    <suppress until="2026-12-31Z">
        <notes>
            FALSE POSITIVE: CVE-2026-42154 targets the Prometheus server
            (prometheus/prometheus on GitHub). OWASP incorrectly matches it against
            micrometer-registry-prometheus via CPE name similarity. Micrometer is a
            metrics facade by the Spring team — not the Prometheus server.
        </notes>
        <packageUrl regex="true">^pkg:maven/io\.micrometer/micrometer\-registry\-prometheus@.*$</packageUrl>
        <cve>CVE-2026-42154</cve>
    </suppress>

    <!-- ═══════════════════════════════════════════════════════════════════════
         netty-transport* — CVE-2026-42582
         VERDICT: FALSE POSITIVE (wrong module + already-fixed version)

         CVE-2026-42582 affects netty-codec-http3, not any netty-transport*
         artifact. OWASP maps all Netty CVEs to the broad CPE
         cpe:2.3:a:netty:netty:* which matches any io.netty:* artifact
         regardless of which specific module is actually affected — same root
         cause as the angus-activation and micrometer-registry-prometheus
         suppressions above.

         Independently of the module mismatch: the fix for CVE-2026-42582
         shipped in the 4.1.133.Final release. Every io.netty:netty-transport*
         artifact in this project is now >= 4.1.135.Final (via Spring Boot
         3.5.15's managed Netty version) — there is no newer patched release to
         upgrade to for this CVE.

         Regex widened from netty-transport only to netty-transport.* after
         netty-transport-native-unix-common-4.1.135.Final.jar started reporting
         this CVE (2026-06-13) once the plain netty-transport artifact was fixed
         by the Spring Boot 3.5.15 upgrade — same false-positive cause, different
         sibling artifact from the same Netty release. Covers netty-transport,
         netty-transport-native-unix-common, and any future netty-transport-native-*
         artifact from the same release.

         Tracked upstream: a near-identical report (5 different Netty CVEs
         mismatched onto netty-transport) was filed against OWASP
         Dependency-Check as issue #8576 on 2026-06-08.
         Reference: https://github.com/dependency-check/DependencyCheck/issues/8576
         ═══════════════════════════════════════════════════════════════════════ -->
    <suppress until="2026-12-31Z">
        <notes>
            FALSE POSITIVE: CVE-2026-42582 affects netty-codec-http3, not any
            netty-transport* artifact. OWASP matches via the broad
            cpe:2.3:a:netty:netty:* CPE that applies to any io.netty:* artifact.
            Additionally, the fix for this CVE shipped in 4.1.133.Final — every
            netty-transport* artifact here is 4.1.135.Final (via Spring Boot
            3.5.15), already past the fixed version.
            Tracked upstream: dependency-check/DependencyCheck#8576
        </notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/netty\-transport.*@.*$</packageUrl>
        <cve>CVE-2026-42582</cve>
    </suppress>

