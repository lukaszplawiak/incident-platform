# Snyk policy file
# https://docs.snyk.io/snyk-cli/test-for-vulnerabilities/the-.snyk-file
#
# This file documents CVEs that cannot be fixed without a major version upgrade
# and have been reviewed and accepted as a known risk.
#
# Review process:
# - Each entry was verified against the affected version and fix version
# - Entries expire automatically — re-evaluate when Spring Boot 4.x is adopted
# - Entries marked "No upgrade available" have no fix at time of writing
#
# To add a new suppression via CLI:
#   snyk ignore --id=SNYK-JAVA-XXX --expiry=YYYY-MM-DD --reason="explanation"

version: v1.25.0

ignore:

  # ── Tomcat (via Spring Boot 3.x) ──────────────────────────────────────────
  # Fix requires upgrade to Spring Boot 4.0 (tomcat 11.x).
  # Breaking major version change — not viable without full Spring Boot 4.x migration.
  # Mitigated by: network-level access control, JWT authentication on all endpoints.

  SNYK-JAVA-ORGAPACHETOMCATEMBED-16643259:
    - '*':
        reason: >
          Tomcat CVE requires upgrade to Spring Boot 4.0 which is a breaking
          major version change. Tracked for resolution during Spring Boot 4.x
          migration. Application does not expose affected Tomcat internals
          directly to untrusted user input. All endpoints require JWT auth.
        expires: '2027-01-01T00:00:00.000Z'

  SNYK-JAVA-ORGAPACHETOMCATEMBED-16691231:
    - '*':
        reason: >
          Tomcat CVE requires upgrade to Spring Boot 4.0 which is a breaking
          major version change. Tracked for resolution during Spring Boot 4.x
          migration. All endpoints require JWT authentication.
        expires: '2027-01-01T00:00:00.000Z'

  # ── Netty (via Spring Boot 3.x / Lettuce / Redis) ─────────────────────────
  # Fix requires upgrade to Spring Boot 4.0 (lettuce-core 6.x -> 7.x -> netty 4.2.x).
  # Redis connection is internal-only, not exposed to untrusted network.

  SNYK-JAVA-IONETTY-16438322:
    - '*':
        reason: >
          Netty CVE requires upgrade to Spring Boot 4.0 via lettuce-core.
          Tracked for resolution during Spring Boot 4.x migration.
          Redis connection is internal network only, not reachable from untrusted clients.
        expires: '2027-01-01T00:00:00.000Z'

  SNYK-JAVA-IONETTY-16438930:
    - '*':
        reason: >
          Netty CVE requires upgrade to Spring Boot 4.0 via lettuce-core.
          Tracked for resolution during Spring Boot 4.x migration.
          Redis connection is internal network only.
        expires: '2027-01-01T00:00:00.000Z'

  # ── lz4-java (via kafka-clients) ──────────────────────────────────────────
  # lz4-java is shaded (embedded) inside the kafka-clients JAR.
  # Cannot be overridden via pom.xml dependency management.
  # Fix requires spring-kafka 4.x which bundles a patched kafka-clients.

  SNYK-JAVA-ORGLZ4-14151788:
    - '*':
        reason: >
          lz4-java 1.8.1 fixes this CVE but it is shaded inside kafka-clients JAR
          and cannot be overridden via pom.xml dependency management.
          Fix requires spring-kafka 4.x migration. Tracked accordingly.
        expires: '2027-01-01T00:00:00.000Z'

  SNYK-JAVA-ORGLZ4-14219384:
    - '*':
        reason: >
          No fix available for this CVE at time of writing (2026-06-06).
          lz4-java is shaded inside kafka-clients JAR and cannot be overridden.
          Will be re-evaluated when a fix version is published.
        expires: '2027-01-01T00:00:00.000Z'

  # ── Kafka clients ──────────────────────────────────────────────────────────
  # kafka.version updated to 3.9.1 in pom.xml — partial fix for some CVEs.
  # Remaining CVEs require spring-kafka 4.x (kafka-clients 4.x).

  SNYK-JAVA-ORGAPACHEKAFKA-10336719:
    - '*':
        reason: >
          Fixed in kafka-clients 3.9.1. kafka.version updated to 3.9.1 in pom.xml.
          Suppression kept pending confirmation from next Snyk scan.
        expires: '2026-12-31T00:00:00.000Z'

  SNYK-JAVA-ORGAPACHEKAFKA-10350513:
    - '*':
        reason: >
          Fixed in kafka-clients 3.9.1. kafka.version updated to 3.9.1 in pom.xml.
          Suppression kept pending confirmation from next Snyk scan.
        expires: '2026-12-31T00:00:00.000Z'

  SNYK-JAVA-ORGAPACHEKAFKA-10350567:
    - '*':
        reason: >
          Fixed in kafka-clients 3.9.1. kafka.version updated to 3.9.1 in pom.xml.
          Suppression kept pending confirmation from next Snyk scan.
        expires: '2026-12-31T00:00:00.000Z'

  SNYK-JAVA-ORGAPACHEKAFKA-16300072:
    - '*':
        reason: >
          Fixed in kafka-clients 3.9.2 / 4.0.1. kafka.version updated to 3.9.1
          in pom.xml — partial fix only. Full fix requires spring-kafka 4.x migration.
          Tracked for resolution during Spring Boot 4.x migration.
        expires: '2027-01-01T00:00:00.000Z'

patch: {}